calar.SolidScalar\", \"org.cactoos.scalar.Solid\");\n            replacements.put(\"org.cactoos.text.JoinedText\", \"org.cactoos.text.Joined\");\n            replacements.put(\"org.cactoos.scalar.StickyScalar\", \"org.cactoos.scalar.Sticky\");\n            replacements.put(\"org.cactoos.text.TrimmedText\", \"org.cactoos.text.Trimmed\");\n        }\n\n        @Override\n        public void process(CtTypeReference<?> ref) {\n            String qName = ref.getQualifiedName();\n            if (replacements.containsKey(qName)) {\n                String newQName = replacements.get(qName);\n                String newSimpleName = newQName.substring(newQName.lastIndexOf('.') + 1);\n                String newPackage = newQName.substring(0, newQName.lastIndexOf('.'));\n                \n                ref.setPackage(getFactory().Package().getOrCreate(newPackage).getReference());\n                ref.setSimpleName(newSimpleName);\n            }\n        }\n    }\n}\n"}},"correlationId":"2b941a4d-d984-4223-9e9e-159d5deba45f"}
