[MESSAGE_BUS] publish: {"type":"tool-confirmation-request","toolCall":{"name":"write_file","args":{"content":"package github.chains.processors;\n\nimport spoon.processing.AbstractProcessor;\nimport spoon.reflect.code.CtInvocation;\nimport spoon.reflect.code.CtLocalVariable;\nimport spoon.reflect.code.CtStatement;\nimport spoon.reflect.declaration.CtElement;\nimport spoon.reflect.declaration.CtField;\nimport spoon.reflect.declaration.CtType;\nimport spoon.reflect.declaration.CtVariable;\nimport spoon.reflect.reference.CtVariableReference;\nimport spoon.reflect.visitor.filter.TypeFilter;\n\nimport java.util.List;\n\npublic class FixLogbackErrorProcessor extends AbstractProcessor<CtType<?>> {\n\n    @Override\n    public boolean isToBeProcessed(CtType<?> candidate) {\n        return candidate.getQualifiedName().equals(\"uk.gov.pay.adminusers.queue.event.EventMessageHandlerTest\");\n    }\n\n    @Override\n    public void process(CtType<?> element) {\n        // 1. Find and remove fields\n        CtField<?> mockLogAppender = element.getField(\"mockLogAppender\");\n        CtField<?> loggingEventArgumentCaptor = element.getField(\"loggingEventArgumentCaptor\");\n\n        if (mockLogAppender != null) {\n            removeUsages(mockLogAppender);\n            mockLogAppender.delete();\n        }\n\n        if (loggingEventArgumentCaptor != null) {\n            removeUsages(loggingEventArgumentCaptor);\n            loggingEventArgumentCaptor.delete();\n        }\n\n        // 2. Remove Logger setup in setUp()\n        // Look for local variable \"logger\" of type ch.qos.logback.classic.Logger\n        List<CtLocalVariable<?>> loggers = element.getElements(new TypeFilter<>(CtLocalVariable.class) {\n            @Override\n            public boolean matches(CtLocalVariable<?> var) {\n                return var.getType() != null && var.getType().getQualifiedName().equals(\"ch.qos.logback.classic.Logger\");\n            }\n        });\n\n        for (CtLocalVariable<?> logger : loggers) {\n            removeUsages(logger);\n            logger.delete();\n        }\n    }\n\n    private void removeUsages(CtVariable<?> variable) {\n        List<CtVariableReference<?>> references = variable.getElements(new TypeFilter<>(CtVariableReference.class));\n        for (CtVariableReference<?> ref : references) {\n            if (ref.getDeclaration() == variable) {\n                CtElement parent = ref.getParent();\n                // Traverse up to find the statement\n                while (parent != null && !(parent instanceof CtStatement)) {\n                    parent = parent.getParent();\n                }\n                if (parent != null) {\n                    // If the statement declares a variable (e.g. List<ILoggingEvent> logStatement = ...),\n                    // we need to remove usages of THAT variable too.\n                    if (parent instanceof CtLocalVariable) {\n                        removeUsages((CtLocalVariable<?>) parent);\n                    }\n                    parent.delete();\n                }\n            }\n        }\n    }\n}\n","file_path":"spoon-base-template/src/main/java/github/chains/processors/FixLogbackErrorProcessor.java"}},"correlationId":"ae09ebbb-86cb-4fc9-9ea8-ad190a414403"}
