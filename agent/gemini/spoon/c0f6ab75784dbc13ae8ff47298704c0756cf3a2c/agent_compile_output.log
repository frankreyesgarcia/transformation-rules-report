[MESSAGE_BUS] publish: {"type":"tool-confirmation-request","toolCall":{"name":"write_file","args":{"content":"package github.chains;\n\nimport spoon.processing.AbstractProcessor;\nimport spoon.reflect.code.CtBlock;\nimport spoon.reflect.code.CtForEach;\nimport spoon.reflect.code.CtInvocation;\nimport spoon.reflect.code.CtLocalVariable;\nimport spoon.reflect.code.CtReturn;\nimport spoon.reflect.code.CtStatement;\nimport spoon.reflect.code.CtVariableRead;\nimport spoon.reflect.declaration.CtMethod;\nimport spoon.reflect.declaration.CtType;\nimport spoon.reflect.reference.CtTypeReference;\nimport spoon.reflect.factory.Factory;\n\nimport java.util.List;\n\npublic class FixSonarLintEngineProcessor extends AbstractProcessor<CtMethod<?>> {\n\n    @Override\n    public boolean isToBeProcessed(CtMethod<?> candidate) {\n        return candidate.getSimpleName().equals(\"buildAnalysisEngineConfiguration\")\n                && candidate.getDeclaringType().getSimpleName().equals(\"SonarLintEngine\");\n    }\n\n    @Override\n    public void process(CtMethod<?> method) {\n        System.out.println(\"Processing method: \" + method.getSignature());\n        Factory factory = getFactory();\n        \n        // Find the return statement\n        if (method.getBody().getStatements().isEmpty()) {\n            return;\n        }\n        CtStatement stmt = method.getBody().getStatement(0);\n        if (!(stmt instanceof CtReturn)) {\n            return;\n        }\n        CtReturn<?> returnStmt = (CtReturn<?>) stmt;\n        if (!(returnStmt.getReturnedExpression() instanceof CtInvocation)) {\n            return;\n        }\n        CtInvocation<?> invocation = (CtInvocation<?>) returnStmt.getReturnedExpression();\n        \n        CtInvocation<?> targetInvocation = null;\n        CtInvocation<?> parentOfTarget = null;\n        CtInvocation<?> current = invocation;\n        \n        while (current != null) {\n            if (current.getExecutable().getSimpleName().equals(\"addEnabledLanguages\")) {\n                targetInvocation = current;\n                break;\n            }\n            if (current.getTarget() instanceof CtInvocation) {\n                parentOfTarget = current;\n                current = (CtInvocation<?>) current.getTarget();\n            } else {\n                current = null;\n            }\n        }\n        \n        if (targetInvocation == null) {\n            System.out.println(\"Could not find addEnabledLanguages invocation\");\n            return;\n        }\n        System.out.println(\"Found addEnabledLanguages invocation\");\n\n        // 1. Create a local variable for the builder\n        CtTypeReference<?> builderType = factory.Type().createReference(\"org.sonarsource.sonarlint.core.analysis.api.AnalysisEngineConfiguration.Builder\");\n        CtInvocation<?> builderInit = (CtInvocation<?>) targetInvocation.getTarget();\n        \n        CtLocalVariable<?> builderVar = factory.Code().createLocalVariable(\n                builderType,\n                \"builder\",\n                builderInit\n        );\n        \n        // 2. Create the for loop\n        CtTypeReference<?> languageType = factory.Type().createReference(\"org.sonarsource.sonarlint.core.commons.Language\");\n        CtLocalVariable<?> loopVar = factory.Code().createLocalVariable(\n                languageType,\n                \"language\",\n                null\n        );\n        \n        CtVariableRead<?> builderRead = factory.Code().createVariableRead(builderVar.getReference(), false);\n        CtVariableRead<?> languageRead = factory.Code().createVariableRead(loopVar.getReference(), false);\n        \n        CtInvocation<?> addEnabledLanguageCall = factory.Code().createInvocation(\n                builderRead,\n                factory.Executable().createReference(builderType, factory.Type().voidType(), \"addEnabledLanguage\", languageType),\n                languageRead\n        );\n        \n        CtBlock<?> loopBody = factory.Code().createBlock();\n        loopBody.addStatement(addEnabledLanguageCall);\n        \n        CtForEach forEach = factory.Core().createForEach();\n        forEach.setVariable(loopVar);\n        forEach.setExpression(targetInvocation.getArguments().get(0));\n        forEach.setBody(loopBody);\n        \n        // 3. Connect the rest of the chain\n        if (parentOfTarget != null) {\n            parentOfTarget.setTarget(builderRead);\n        } else {\n            // If addEnabledLanguages was the last call (e.g. return ...addEnabledLanguages(...)),\n            // then we should return builderVar (but builderVar is void? No, addEnabledLanguages returns Builder).\n            // But we changed it to a loop calling addEnabledLanguage (void or Builder).\n            // If the original code was returning the Builder, we should return builderVar.\n            \n            // In the specific case of buildAnalysisEngineConfiguration, the chain ends with .build() which returns AnalysisEngineConfiguration.\n            // So parentOfTarget should NOT be null.\n            System.out.println(\"Warning: parentOfTarget is null, this is unexpected for buildAnalysisEngineConfiguration\");\n        }\n        \n        CtBlock<?> newBody = factory.Code().createBlock();\n        newBody.addStatement(builderVar);\n        newBody.addStatement(forEach);\n        newBody.addStatement(returnStmt);\n        \n        method.setBody(newBody);\n        System.out.println(\"Transformation applied.\");\n    }\n}\n","file_path":"spoon-base-template/src/main/java/github/chains/FixSonarLintEngineProcessor.java"}},"correlationId":"35ef0b2c-d4ff-47f0-943d-d63139d6d9b2"}
