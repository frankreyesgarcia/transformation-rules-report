[MESSAGE_BUS] publish: {"type":"tool-confirmation-request","toolCall":{"name":"write_file","args":{"content":"package github.chains;\n\nimport spoon.Launcher;\nimport spoon.reflect.CtModel;\nimport spoon.reflect.code.CtInvocation;\nimport spoon.reflect.declaration.CtElement;\nimport spoon.reflect.reference.CtTypeReference;\nimport spoon.reflect.visitor.filter.TypeFilter;\n\nimport java.io.File;\n\npublic class Main {\n    public static void main(String[] args) {\n        String projectPath = \"/workspace/java-pubsub-group-kafka-connector/src/main/java\";\n        String outputPath = \"/workspace/spoon-base-template/target/spooned\";\n\n        Launcher launcher = new Launcher();\n        launcher.addInputResource(projectPath);\n        launcher.getEnvironment().setNoClasspath(true);\n        launcher.getEnvironment().setAutoImports(true);\n        launcher.getEnvironment().setCommentEnabled(true);\n        launcher.setSourceOutputDirectory(outputPath);\n\n        launcher.buildModel();\n        CtModel model = launcher.getModel();\n\n        // 1. Rename PublishMetadata to MessageMetadata\n        for (CtTypeReference<?> ref : model.getElements(new TypeFilter<>(CtTypeReference.class))) {\n            if (\"com.google.cloud.pubsublite.PublishMetadata\".equals(ref.getQualifiedName())) {\n                ref.setSimpleName(\"MessageMetadata\");\n            }\n        }\n\n        // 2. Remove setContext call\n        // Pattern: SinglePartitionPublisherBuilder.newBuilder()... .setContext(...).build()\n        // We look for invocation of setContext with arguments containing PubsubContext\n        for (CtInvocation<?> invocation : model.getElements(new TypeFilter<>(CtInvocation.class))) {\n            if (\"setContext\".equals(invocation.getExecutable().getSimpleName())) {\n                 // Check arguments to be safer\n                 boolean isTarget = false;\n                 for (CtElement arg : invocation.getArguments()) {\n                     if (arg.toString().contains(\"PubsubContext\")) {\n                         isTarget = true;\n                         break;\n                     }\n                 }\n                 \n                 if (isTarget) {\n                     // Replace the invocation with its target (the previous link in the chain)\n                     // e.g. X.foo().setContext(arg).bar()\n                     // setContext(arg) is the target of bar()\n                     // foo() is the target of setContext(arg)\n                     // we want X.foo().bar()\n                     // So we replace setContext(arg) with foo()\n                     \n                     CtElement target = invocation.getTarget();\n                     if (target != null) {\n                         invocation.replace(target);\n                     }\n                 }\n            }\n        }\n\n        launcher.prettyprint();\n        System.out.println(\"Spoon transformation completed.\");\n    }\n}\n","file_path":"spoon-base-template/src/main/java/github/chains/Main.java"}},"correlationId":"b70bf16b-cb45-4e12-bf19-bcc89b8fad23"}
