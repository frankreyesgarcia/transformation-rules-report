teReference(Collection.class);\n        colClassName.addActualTypeArgument(classNameType);\n        classesParam.setType((CtTypeReference) colClassName);\n\n        // Update getPackageName: this.classes.iterator().next().getName().asJavaName() -> this.classes.iterator().next().asJavaName()\n        CtMethod<?> getPackageName = summaryData.getMethod(\"getPackageName\");\n        // We need to remove .getName() call\n        // The expression is likely: this.classes.iterator().next().getName().asJavaName().replace(...)\n        // We want: this.classes.iterator().next().asJavaName().replace(...)\n        \n        // Let's do a replace of invocation\n        List<CtInvocation<?>> invocations = getPackageName.getElements(new TypeFilter<>(CtInvocation.class));\n        for (CtInvocation<?> inv : invocations) {\n            if (inv.getExecutable().getSimpleName().equals(\"getName\")) {\n                 // Replace inv with inv.getTarget()\n                 // inv is a.getName()\n                 // we want 'a'\n                 // But wait, we are calling .asJavaName() on the result of .getName().\n                 // So we have b.asJavaName() where b = a.getName()\n                 // We want a.asJavaName()\n                 \n                 // Actually, let's find .getName() call.\n                 // It is invoked on ClassInfo object.\n                 // Now we have ClassName object.\n                 // ClassInfo.getName() -> ClassName\n                 // ClassName.asJavaName() -> String\n                 \n                 // If we have ClassName object 'c', we just call c.asJavaName().\n                 // Before: info.getName().asJavaName()\n                 // After: name.asJavaName() (where name is ClassName)\n                 \n                 // So we just need to remove the .getName() call.\n                 inv.replace(inv.getTarget());\n            }\n        }\n        \n        // Update getClasses return type\n        CtMethod<?> getClasses = summaryData.getMethod(\"getClasses\");\n        getClasses.setType((CtTypeReference) colClassName);\n\n\n        // 2. Modify MutationReportListener\n        CtClass<?> listener = model.getElements(new TypeFilter<CtClass<?>>(CtClass.class) {\n            @Override\n            public boolean matches(CtClass<?> element) {\n                return element.getQualifiedName().equals(\"org.pitest.elements.MutationReportListener\");\n            }\n        }).get(0);\n\n        CtMethod<?> createSummaryData = listener.getMethod(\"createSummaryData\");\n        // Update invocation of constructor\n        // return new MutationTestSummaryData(..., coverage.getClassInfo(...))\n        // Change to: return new MutationTestSummaryData(..., Collections.singleton(data.getMutatedClass()))\n        \n        List<CtConstructorCall> constCalls = createSummaryData.getElements(new TypeFilter<>(CtConstructorCall.class));\n        for (CtConstructorCall call : constCalls) {\n            if (call.getType().getQualifiedName().equals(\"org.pitest.elements.models.MutationTestSummaryData\")) {\n                CtExpression<?> thirdArg = (CtExpression<?>) call.getArguments().get(2);\n                // thirdArg is coverage.getClassInfo(Collections.singleton(data.getMutatedClass()))\n                // We want just Collections.singleton(data.getMutatedClass())\n                \n                if (thirdArg instanceof CtInvocation) {\n                    CtInvocation inv = (CtInvocation) thirdArg;\n                    if (inv.getExecutable().getSimpleName().equals(\"getClassInfo\")) {\n                        CtExpression<?> arg = (CtExpression<?>) inv.getArguments().get(0);\n                        // arg is Collections.singleton(...)\n                        // Replace thirdArg with arg\n                        thirdArg.replace(arg);\n                    }\n                }\n            }\n        }\n\n\n        // 3. Modify JsonParser\n        CtClass<?> jsonParser = model.getElements(new Type