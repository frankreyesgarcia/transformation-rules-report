s PTSimpleInvoicePDFTransformer {\n    public PTSimpleInvoicePDFFOPTransformer(MathContext mathContext, String logoImagePath, InputStream xsltFileStream, String softwareCertificationId, Config config) {\n        super(PTSimpleInvoiceData.class, mathContext, logoImagePath, xsltFileStream, softwareCertificationId, config);\n    }\n\n    public PTSimpleInvoicePDFFOPTransformer(String logoImagePath, InputStream xsltFileStream, String softwareCertificationId) {\n        this(BillyMathContext.get(), logoImagePath, xsltFileStream, softwareCertificationId, new Config());\n    }\n\n    public PTSimpleInvoicePDFFOPTransformer(PTSimpleInvoiceTemplateBundle bundle) {\n        super(PTSimpleInvoiceData.class, BillyMathContext.get(), bundle, new Config());\n    }\n\n    @Override\n    protected ParamsTree<String, String> mapDocumentToParamsTree(PTSimpleInvoiceData invoice) {\n        ParamsTree<String, String> params = super.mapDocumentToParamsTree(invoice);\n        params.getRoot().addChild(PTParamKeys.INVOICE_HASH, this.getVerificationHashString(invoice.getHash()));\n        invoice.getQrCodeString().ifPresent(s -> params.getRoot().addChild(PTParamKeys.QRCODE, s));\n        params.getRoot().addChild(PTParamKeys.ATCUD, invoice.getAtcud());\n        params.getRoot().addChild(PTParamKeys.SOFTWARE_CERTIFICATE_NUMBER, this.getSoftwareCertificationId());\n        return params;\n    }\n\n    @Override\n    protected void setHeader(ParamsTree<String, String> params, PTSimpleInvoiceData entity) {\n        params.getRoot().addChild(ParamKeys.ID, entity.getNumber());\n        if (null != entity.getPayments()) {\n            for (PaymentData p : entity.getPayments()) {\n                params.getRoot().addChild(ParamKeys.INVOICE_PAYMETHOD, this.getPaymentMechanismTranslation(p.getPaymentMethod()));\n            }\n        }\n        params.getRoot().addChild(ParamKeys.EMISSION_DATE, DateTimeFormatter.ISO_LOCAL_DATE.format(entity.getLocalDate()));\n    }\n\n    @Override\n    protected void setCustomer(ParamsTree<String, String> params, PTSimpleInvoiceData entity) {\n        Node<String, String> customer = params.getRoot().addChild(ParamKeys.CUSTOMER);\n        customer.addChild(ParamKeys.CUSTOMER_FINANCIAL_ID, this.getCustomerFinancialId(entity));\n    }\n}\n"}},"correlationId":"8d832c18-2f84-4c9c-a874-3372c011a33b"}
