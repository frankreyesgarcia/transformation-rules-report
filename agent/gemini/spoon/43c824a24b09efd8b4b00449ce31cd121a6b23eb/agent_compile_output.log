[MESSAGE_BUS] publish: {"type":"tool-confirmation-request","toolCall":{"name":"write_file","args":{"content":"package github.chains;\n\nimport spoon.Launcher;\nimport spoon.reflect.CtModel;\nimport spoon.reflect.code.CtInvocation;\nimport spoon.reflect.declaration.CtImport;\nimport spoon.reflect.declaration.CtType;\nimport spoon.reflect.reference.CtTypeReference;\nimport spoon.reflect.visitor.CtScanner;\n\nimport java.util.HashSet;\nimport java.util.Set;\nimport java.util.stream.Collectors;\n\npublic class JsonBranchTransformer {\n    public static void main(String[] args) {\n        // Process main sources\n        process(\"/workspace/qa-catalogue/src/main/java\");\n        // Process test sources\n        process(\"/workspace/qa-catalogue/src/test/java\");\n    }\n\n    private static void process(String inputDir) {\n        System.out.println(\"Processing: \" + inputDir);\n        Launcher launcher = new Launcher();\n        launcher.addInputResource(inputDir);\n        \n        // Environment settings\n        launcher.getEnvironment().setAutoImports(true);\n        launcher.getEnvironment().setNoClasspath(true);\n        launcher.getEnvironment().setCommentEnabled(true);\n        \n        // Output directory - overwrite input\n        launcher.setSourceOutputDirectory(inputDir);\n\n        CtModel model = launcher.buildModel();\n\n        for (CtType<?> type : model.getAllTypes()) {\n            type.accept(new CtScanner() {\n                @Override\n                public <T> void visitCtTypeReference(CtTypeReference<T> reference) {\n                    if (\"JsonBranch\".equals(reference.getSimpleName())) {\n                        if (reference.getPackage() == null || \"de.gwdg.metadataqa.api.json\".equals(reference.getPackage().getQualifiedName())) {\n                             reference.setSimpleName(\"DataElement\");\n                        }\n                    }\n                    super.visitCtTypeReference(reference);\n                }\n\n                @Override\n                public <T> void visitCtInvocation(CtInvocation<T> invocation) {\n                    if (\"getJsonPath\".equals(invocation.getExecutable().getSimpleName())) {\n                        invocation.getExecutable().setSimpleName(\"getPath\");\n                    }\n                    super.visitCtInvocation(invocation);\n                }\n            });\n        }\n        \n        // Manually fix imports because auto-imports in noclasspath mode can be tricky\n        model.getUnnamedModule().getFactory().CompilationUnit().getMap().values().forEach(cu -> {\n            Set<CtImport> importsToRemove = new HashSet<>();\n            boolean needsNewImport = false;\n\n            for (CtImport imp : cu.getImports()) {\n                if (imp.getReference() instanceof CtTypeReference) {\n                    CtTypeReference<?> ref = (CtTypeReference<?>) imp.getReference();\n                    if (\"de.gwdg.metadataqa.api.json.JsonBranch\".equals(ref.getQualifiedName())) {\n                        importsToRemove.add(imp);\n                        needsNewImport = true;\n                    }\n                }\n            }\n            \n            if (needsNewImport) {\n                for (CtImport imp : importsToRemove) {\n                    cu.getImports().remove(imp);\n                }\n                \n                CtTypeReference<?> newRef = launcher.getFactory().createTypeReference();\n                newRef.setSimpleName(\"DataElement\");\n                newRef.setPackage(launcher.getFactory().Package().getOrCreate(\"de.gwdg.metadataqa.api.json\"));\n                \n                CtImport newImport = launcher.getFactory().createImport(newRef);\n                cu.getImports().add(newImport);\n            }\n        });\n\n        launcher.prettyprint();\n        System.out.println(\"Finished processing: \" + inputDir);\n    }\n}\n","file_path":"/workspace/spoon-base-template/src/main/java/github/chains/JsonBranchTransformer.java"}},"correlationId":"ae0018b8-a046-4814-8b20-beea09b752aa"}
